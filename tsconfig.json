{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    
    // Change these two lines to NodeNext:
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    "target": "es2023",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  },
  "exclude": ["./node_modules", "./dist", "./prisma.config.ts"]
}